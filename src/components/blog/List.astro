---
import Item from '~/components/blog/ListItem.astro';
import type { Post } from '~/types';
// import { Image } from 'astro:assets';

export interface Props {
  posts: Array<Post>;
}

const { posts } = Astro.props;

const featuredPost = posts[0];
const otherPosts = posts.slice(1);
// const featuredPostImage = featuredPost.images.at(0);

// console.log('Featured Post:', featuredPost);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
 
  

const getCategory = (post: Post) => {
  if (post.category && post.category.title) {
    return post.category.title;
  }
  if (post.tags && post.tags.length > 0) {
    return post.tags[0].title;
  }
  return '博客';
};
---

<div class="max-w-5xl mx-auto">
  {featuredPost && (
    <a
      href={featuredPost.permalink}
      class="group block relative rounded-2xl overflow-hidden mb-8 border border-white/10 hover:border-gold/60 transition-colors"
    >
      <div class="aspect-[16/9] sm:aspect-[21/9] bg-[#1d1d1d] overflow-hidden">

        {featuredPost.coverImage && (
          <img
            src={featuredPost.coverImage}
            alt={featuredPost.title || ''}
            class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700"
          />
        )} 

      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-5 sm:p-8">
        <span class="text-gold text-xs font-bold uppercase tracking-[0.12em]">{getCategory(featuredPost)}</span>
        <h2 class="mt-2 text-xl sm:text-3xl font-bold leading-tight max-w-2xl">
          {featuredPost.title}
        </h2>
        <p class="mt-2 text-xs sm:text-sm text-white/60">
          {formatDate(featuredPost.publishDate)} · {featuredPost.readingTime || 3} 分鐘
        </p>
      </div>
    </a>
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {otherPosts.map((post) => (
      <a
        href={post.permalink}
        class="group block bg-[#161616] border border-white/10 rounded-xl overflow-hidden hover:border-gold/60 transition-colors"
      >
        <div class="aspect-[16/10] overflow-hidden bg-[#1d1d1d]">
         {post.coverImage && (
          <img
            src={post.coverImage}
            alt={post.title || ''}
            loading="lazy"
            class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
          />
        )} 

        </div>
        <div class="p-4">
          <span class="text-gold text-[11px] font-bold uppercase tracking-[0.12em]">{getCategory(post)}</span>
          <h3 class="mt-1 text-sm font-bold leading-snug text-white/90 line-clamp-2">
            {post.title}
          </h3>
          <p class="mt-2 text-[11px] text-white/40">
            {formatDate(post.publishDate)} · {post.readingTime || 2} 分鐘
          </p>
        </div>
      </a>
    ))}
  </div>
</div>

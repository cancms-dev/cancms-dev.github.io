---
import ContactSection from '../islands/ContactSection.astro';
import { getPermalink, langLink } from '~/utils/permalinks';

interface Props {
  lang: string;
}

const { lang } = Astro.props as Props;
---

<!-- 不知道选哪间？让我们帮你推荐 -->
<section class="not-known-recommends pb-12 px-4">
  <div class="max-w-3xl mx-auto">
    <div
      class="fade-up bg-gradient-to-r from-[#141414] to-[#1a1a1a] border border-gold/10 rounded-2xl p-8 text-center in-view"
    >
      <h3 class="text-xl font-bold mb-3">不知道選哪間？讓我們幫你推薦</h3>
      <p class="text-white/50 text-sm mb-6">聯繫我們，根據你的喜好推薦最適合的場所</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="#contact"
          class="px-6 py-2.5 bg-gold hover:bg-gold-dark text-black font-semibold rounded-full transition-all duration-300 text-sm"
          >與我們聊聊</a
        >
        <a
          href={langLink('ranking')}
          class="px-6 py-2.5 border border-gold/50 text-gold hover:bg-gold/10 rounded-full transition-all duration-300 text-sm"
          >排名</a
        >
        <a
          href={langLink('guide')} 
          class="px-6 py-2.5 border border-gold/50 text-gold hover:bg-gold/10 rounded-full transition-all duration-300 text-sm"
          >新手指南</a
        >
        <a
          href={langLink('faq')}
          class="px-6 py-2.5 border border-gold/50 text-gold hover:bg-gold/10 rounded-full transition-all duration-300 text-sm"
          >常見問題</a
        >
      </div>
    </div>
  </div>
</section>

<!-- 联系我们 -->
<section id="contact" class="pt-14 pb-20 sm:pt-20 sm:pb-28 px-4 scroll-mt-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">聯繫我們</h2>
      <div class="w-20 h-0.5 bg-gold mx-auto mb-6"></div>
      <p class="text-white/50">隨時歡迎您的諮詢，我們將竭誠為您服務</p>
    </div> 
     <ContactSection lang={lang} client:visible />
  </div>
</section>

<!-- 我们不只是提供服务，我们真心在乎您的快乐 -->
<section class="pb-12 sm:pb-16 px-4">
  <div class="max-w-3xl mx-auto">
    <div
      data-testid="mission-section"
      class="bg-gradient-to-b from-gold/10 to-gold/5 border border-gold/25 rounded-2xl px-6 py-7 sm:px-8 sm:py-9"
    >
      <p class="text-gold italic text-xs sm:text-sm opacity-90 mb-4 text-center">
        我們不只是提供服務，我們真心在乎您的快樂。
      </p>
      <p class="text-white/85 text-sm sm:text-base leading-relaxed max-w-2xl mx-auto text-left whitespace-pre-line">
        澳門的根本是款待。每一位客人都值得擁有一段難以忘懷的時光——不是「還可以」，而是真正記得一輩子的體驗。
        我們所做的這一切，就是為了讓您的桑拿體驗成為您從澳門帶回去最美好的回憶之一。
      </p>
    </div>
  </div>
</section>

  { name: '巨亨桑拿', slug: 'empire-sauna', district: '澳門半島', therapists: '多國籍技師團隊', hours: '17:00 - 06:00', open24h: true, rating: 5, price: '2,488 – 7,388', serviceFee: '10%', buyOneGetOne: '問我們', overnight: true, freeRoom: false, lounge: true, ktv: false, theme: true, lineup: true, isNew: false },
  { name: '凱旋桑拿', slug: 'victoria-sauna', district: '澳門半島', therapists: '70+', hours: '13:00 - 05:00', open24h: true, rating: 4, price: '2,298 – 6,998', serviceFee: '10%', buyOneGetOne: 'OK', overnight: true, freeRoom: false, lounge: true, ktv: false, theme: false, lineup: false, isNew: false },
  { name: '晉會MCLUB', slug: 'm-club', district: '澳門半島', therapists: '60+', hours: '15:00 - 05:00', open24h: true, rating: 4, price: '2,388 – 6,498', serviceFee: '10%', buyOneGetOne: '–', overnight: true, freeRoom: false, lounge: true, ktv: true, theme: true, lineup: false, isNew: false },
  { name: '帝湖桑拿', slug: 'di-hu', district: '氹仔', therapists: '140+', hours: '24 小時駐場', open24h: true, rating: 5, price: '2,299 – 7,099', serviceFee: '10%', buyOneGetOne: '問我們', overnight: true, freeRoom: false, lounge: true, ktv: false, theme: true, lineup: true, isNew: false },
  { name: '壹號桑拿', slug: 'number-one-sauna', district: '澳門半島', therapists: '130+', hours: '13:00 - 05:00', open24h: true, rating: 5, price: '2,199 – 7,699', serviceFee: '10%', buyOneGetOne: '–', overnight: true, freeRoom: false, lounge: true, ktv: false, theme: false, lineup: true, isNew: false },
  { name: '豪門桑拿殿', slug: 'haomen-sauna', district: '澳門半島', therapists: '80+', hours: '16:00 - 06:00', open24h: true, rating: 5, price: '2,388 – 6,988', serviceFee: '免服務費', buyOneGetOne: '–', overnight: true, freeRoom: false, lounge: true, ktv: false, theme: false, lineup: false, isNew: false },

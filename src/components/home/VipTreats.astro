<section id="vip-treats" data-testid="vip-treats-section" class="py-16 sm:py-24 px-4 scroll-mt-6">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-3">
      <div
        class="inline-block bg-green-500/15 text-green-400 text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4"

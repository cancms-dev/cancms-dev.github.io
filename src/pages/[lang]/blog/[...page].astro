---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { blogListRobots, getStaticPathsBlogList, fetchPosts } from '~/utils/blog';
import { Icon } from 'astro-icon/components';
import { langLink } from '~/utils/permalinks';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  // 直接使用 paginate 生成路径，并明确指定 lang 参数
  const posts = await fetchPosts();
  return paginate(posts, {
    params: { lang: 'zh-TW' },
    pageSize: 10,
    // pageSize: 2,
  });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

// console.log('Current Page:', page);

const metadata = {
  title: `桑拿攻略${currentPage > 1 ? ` — 第 ${currentPage} 頁` : ''}`,
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <section class="relative pb-10 s px-4 pt-[9.5rem] sm:pt-[12rem]">
    <div class="absolute inset-0 bg-gradient-to-b from-[#141414] via-[#0f0f0f] to-[#0a0a0a]"></div>
    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="fade-up">
        <a
          href={langLink('/')}
          class="inline-flex items-center gap-2 text-white/50 hover:text-gold transition-colors mb-8 text-sm"
        >
          <Icon name="lucide:arrow-left" class="w-4 h-4" />
          返回首頁
        </a>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 tracking-wider">桑拿攻略</h1>
        <p class="text-white/50 text-base sm:text-lg max-w-xl leading-relaxed">
          實地走訪的澳門桑拿攻略、新場比較與市場更新。
        </p>
        <div class="w-20 h-0.5 bg-gold mt-6"></div>
      </div>

      <!-- 在 <script> 标签上添加 data-astro-rerun 属性，Astro 会在每次页面切换后重新执行该脚本 -->
      <script type="module" data-astro-rerun>
        setTimeout(() => {
          document.querySelectorAll('.fade-up:not(.in-view)').forEach((el) => el.classList.add('in-view'));
        }, 200);
      </script>
    </div>
 
  </section>

  <section class="px-4 pb-20 sm:pb-28"> 
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url?.prev} nextUrl={page.url?.next} />
  </section>
  



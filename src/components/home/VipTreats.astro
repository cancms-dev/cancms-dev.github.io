    </div>
    <div
      role="tablist"
      data-testid="vip-tablist"
      class=" top-16 sm:top-20 z-40 -mx-4 px-4 sm:mx-0 sm:px-0 flex border-b border-gold/15 mb-6 bg-[#0a0a0a]/95 backdrop-blur-sm"

---
// VipExtrasDrawer.astro - 静态抽屉组件
// 使用纯 CSS 控制显示/隐藏，无需 React 水合

const vipExtras = [
  {
    id: 'back-scrub',
    name: '擦背服務',
    desc: '專業擦背服務，舒緩肩頸與背部緊繃。',
    icon: '🧎‍♀️',
    price: '298 MOP',
  },
  {
    id: 'leg-massage',
    name: '腿部按摩',
    desc: '大腿前後深層放鬆，桑拿後最對症。',
    icon: '🦵',
    price: '288 MOP',
  },
  {
    id: 'head-massage',
    name: '頭部按摩',
    desc: '頭皮揉壓，緩解頭痛與精神疲勞。',
    icon: '💆',
    price: '230 MOP',
  },
  {
    id: 'foot-massage',
    name: '足底按摩',
    desc: '穴位按壓，喚醒疲憊雙足。',
    icon: '🦶',
    price: '230 MOP',
  },
  {
    id: 'finger-nail',
    name: '修手指甲',
    desc: '修剪、塑形、護理甲緣。',
    icon: '🤚',
    price: '220 MOP',
  },
  {
    id: 'toe-nail',
    name: '修腳指甲',
    desc: '泡腳、修甲、甲緣護理、足部放鬆。',
    icon: '🧴',
    price: '220 MOP',
  },
  {
    id: 'hand-massage',
    name: '手部按摩',
    desc: '釋放手腕與前臂的緊繃感。',
    icon: '🤲',
    price: '200 MOP',
  },
  {
    id: 'ear-cleaning',
    name: '採耳',
    desc: '傳統採耳體驗，意外地讓人放鬆。',
    icon: '👂',
    price: '200 MOP',
  },
];

const title = '您的 VIP 尊享';
const subtitle = '任選 1 項——我們會事先通知場地您的到訪，到場時可直接挑選。';
---

<!-- 抽屉容器 - 默认隐藏 -->
<div
  id="vip-extras-drawer"
  class="vip-drawer-container fixed inset-0 z-[60] transition-opacity duration-300 opacity-0 pointer-events-none invisible"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="vip-extras-drawer-title"
>
  <!-- 遮罩层 -->
  <div
    id="vip-drawer-overlay"
    class="absolute inset-0 bg-black/70 transition-opacity duration-300 opacity-0"
  ></div>

  <!-- 抽屉主体 - 从右边滑入 -->
  <div
    id="vip-drawer-panel"
    class="fixed bg-[#0f0f0f] border-white/10 shadow-2xl flex flex-col inset-0 pb-[env(safe-area-inset-bottom)] sm:inset-y-0 sm:right-0 sm:left-auto sm:w-[440px] sm:border-l sm:pb-0 transition-transform duration-300 ease-out translate-x-full"
  >
    <!-- 头部 -->
    <div class="flex items-start justify-between gap-4 p-5 sm:p-6 border-b border-white/5">
      <div>
        <h2 id="vip-extras-drawer-title" class="text-xl sm:text-2xl font-bold text-white">
          您的 <span class="text-gold">VIP 尊享</span>
        </h2>
        <p class="text-sm text-white/60 mt-2">
          任選 1 項——我們會事先通知場地您的到訪，到場時可直接挑選。
        </p>
      </div>
      <button
        id="vip-drawer-close"
        type="button"
        aria-label="關閉 VIP 尊享"
        class="flex-shrink-0 p-2.5 rounded-full bg-white/10 text-white ring-1 ring-white/15 hover:bg-white/20 active:bg-white/25 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-6 h-6"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <!-- 内容列表 -->
    <div class="relative flex-1 min-h-0">
      <div class="scrollbar-hide absolute inset-0 overflow-y-auto px-5 sm:px-6 py-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th scope="col" class="text-left pb-2 text-xs uppercase tracking-wider text-white/40 font-normal">
                服務項目
              </th>
              <th scope="col" class="text-right pb-2 text-xs uppercase tracking-wider text-white/40 font-normal">
                價值
              </th>
              <th scope="col" class="text-right pb-2 pl-2 text-xs uppercase tracking-wider text-gold font-normal">
                VIP
              </th>
            </tr>
          </thead>
          <tbody>
            {vipExtras.map((item) => (
              <tr key={item.id} class="border-b border-white/5">
                <td class="py-3 pr-2 align-top">
                  <div class="flex items-start gap-2">
                    <span class="text-xl flex-shrink-0 leading-none mt-0.5" aria-hidden="true">
                      {item.icon}
                    </span>
                    <div class="min-w-0">
                      <div class="font-semibold text-white">{item.name}</div>
                      <div class="text-xs text-white/55 mt-0.5 leading-relaxed">{item.desc}</div>
                    </div>
                  </div>
                </td>
                <td class="text-right text-white/45 align-top py-3 whitespace-nowrap line-through">
                  {item.price}
                </td>
                <td class="text-right text-gold font-semibold align-top py-3 pl-2 pr-1 whitespace-nowrap">
                  免費
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- 底部提示 -->
    <div class="p-5 sm:p-6 border-t border-white/5 bg-black/40">
      <p class="text-xs text-white/50 text-center">
        我們會事先通知場地您的到訪——到場時可直接挑選您喜歡的。
      </p>
    </div>
  </div>
</div>

<!-- 控制脚本 -->
<script>
  // 打开抽屉
  function openVipDrawer() {
    const container = document.getElementById('vip-extras-drawer');
    const overlay = document.getElementById('vip-drawer-overlay');
    const panel = document.getElementById('vip-drawer-panel');

    if (!container || !overlay || !panel) return;

    // 显示容器
    container.classList.remove('opacity-0', 'pointer-events-none', 'invisible');
    container.classList.add('opacity-100', 'pointer-events-auto', 'visible');

    // 显示遮罩
    overlay.classList.remove('opacity-0');
    overlay.classList.add('opacity-100');

    // 滑入面板
    panel.classList.remove('translate-x-full');
    panel.classList.add('translate-x-0');

    // 更新 aria-hidden
    container.setAttribute('aria-hidden', 'false');
  }

  // 关闭抽屉
  function closeVipDrawer() {
    const container = document.getElementById('vip-extras-drawer');
    const overlay = document.getElementById('vip-drawer-overlay');
    const panel = document.getElementById('vip-drawer-panel');

    if (!container || !overlay || !panel) return;

    // 滑出面板
    panel.classList.remove('translate-x-0');
    panel.classList.add('translate-x-full');

    // 隐藏遮罩
    overlay.classList.remove('opacity-100');
    overlay.classList.add('opacity-0');

    // 隐藏容器（等待动画完成）
    setTimeout(() => {
      container.classList.remove('opacity-100', 'pointer-events-auto', 'visible');
      container.classList.add('opacity-0', 'pointer-events-none', 'invisible');
      container.setAttribute('aria-hidden', 'true');
    }, 300); // 与 CSS transition-duration 匹配

    // 将焦点移回触发按钮
    const trigger = document.querySelector('[data-open-vip-drawer]');
    if (trigger) {
      setTimeout(() => trigger.focus(), 50);
    }
  }

  // 使用事件委托监听所有点击事件（无需等待 DOMContentLoaded）
  // 监听所有 data-open-vip-drawer 按钮
  document.addEventListener('click', (e) => {
    const target = e.target.closest('[data-open-vip-drawer]');
    if (target) {
      e.preventDefault();
      openVipDrawer();
    }
  });

  // 监听关闭按钮（使用事件委托）
  document.addEventListener('click', (e) => {
    const closeBtn = e.target.closest('#vip-drawer-close');
    if (closeBtn) {
      e.preventDefault();
      closeVipDrawer();
    }
  });

  // 点击遮罩关闭（使用事件委托）
  document.addEventListener('click', (e) => {
    const overlay = e.target.closest('#vip-drawer-overlay');
    if (overlay) {
      e.preventDefault();
      closeVipDrawer();
    }
  });

  // ESC 键关闭
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const container = document.getElementById('vip-extras-drawer');
      if (container && container.getAttribute('aria-hidden') === 'false') {
        closeVipDrawer();
      }
    }
  });

  // 使用 Astro 的 page-load 事件重新绑定（备选方案）
  document.addEventListener('astro:page-load', () => {
    // 事件委托已经在全局生效，无需额外操作
    // 但确保任何动态添加的元素也能被捕获
  });

  // 暴露给全局，方便调试
  window.openVipDrawer = openVipDrawer;
  window.closeVipDrawer = closeVipDrawer;
</script>

<style is:global>
  /* 抽屉容器初始状态 */
  #vip-extras-drawer {
    transition: opacity 0.3s ease;
  }

  /* 遮罩层过渡 */
  #vip-drawer-overlay {
    transition: opacity 0.3s ease;
  }

  /* 面板滑入滑出 */
  #vip-drawer-panel {
    transition: transform 0.3s ease-out;
  }

  /* 自定义滚动条隐藏 */
  .scrollbar-hide::-webkit-scrollbar {
    width: 0px;
    background: transparent;
  }
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
</style>

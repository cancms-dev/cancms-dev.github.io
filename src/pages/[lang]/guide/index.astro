---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import PageLayout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import ContactSection from '~/components/widgets/ContactSection.astro';
import QuickMatch from '~/components/home/QuickMatch.astro';
import Testimonials from '~/components/home/Testimonials.astro';

export async function getStaticPaths() {
  const languages = ['zh-TW', 'zh-CN', 'en', 'ja'];
  return languages.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const metadata = {
  title: '澳門桑拿新手指南｜第一次來就看這篇',
  description: '第一次來澳門桑拿？完整流程、場所推薦、實用貼士、客戶評價，我們幫你安排一切，從接送到場所推薦。',
};

const allSpas = await getCollection('spa');
const countSpas = allSpas.length;

const message = `你好，我想預約澳門桑拿，可以安排嗎？`;
const lineLink = `https://line.me/ti/p/${SITE.params.contacts.line.id}`;
const whatsAppLink = `https://wa.me/${SITE.params.contacts.whatsApp.id}?text=${message}`;

// 从数据文件读取的会所信息
// name, slug, seoDescription 直接从数据文件提取
const featuredSpas = [
  {
    id: 'empire-sauna',
    tag: '新開頂級奢華',
    name: '巨亨桑拿',
    description:
      '帝濠桑拿是澳門最新的奢華桑拿水療會所，於 2026 年 5 月 1 日進駐氹仔君怡酒店全新開業。全澳最大走秀大廳，國際技師團隊，極致奢華體驗。',
  },
  {
    id: 'majesty-spa',
    tag: '豪華環境',
    name: '尊貴水療',
    description:
      '尊貴水療是澳門最奢華的頂級水療會所之一，斥資過億裝修，房間全澳最大且設有獨立浴缸。全澳唯一提供免費獨立休息房過夜，無需與他人共用躺椅區，是最舒適的留宿選擇。',
  },
  {
    id: 'manhao-spa',
    tag: '全澳最大走秀舞台',
    name: '曼濠水療',
    description:
      '曼濠水療是澳門最新的奢華桑拿水療會所，於 2026 年 5 月 1 日進駐氹仔君怡酒店全新開業。全澳最大走秀大廳，國際技師團隊，極致奢華體驗。',
  },
  {
    id: 'number-nine-sauna',
    tag: '全新體驗',
    name: '玖號水療',
    description:
      '玖號水療是澳門最新的現代奢華水療會所，2026 年 4 月全新開業。配備專業舞台燈光技師介紹、多款氛圍主題房間，提供巴厘島式及日式按摩。開業優惠期間價格最具吸引力。',
  },
  {
    id: 'shangpin-spa',
    tag: '入住葡京人（路氹）',
    name: '尚品國際水療',
    description:
      '尚品國際水療位於路氹葡京人酒店內，住在該區域可零步驟抵達。澳門最新場所之一，裝潢高檔，並有全天買一送一優惠。',
  },
  {
    id: 'the-excellent-sauna',
    tag: '24小時體驗',
    name: '極品桑拿',
    description:
      '極品桑拿是全澳唯一24小時有技師在班的場所，不受時間限制。同時提供水床服務及主題房間（辦公室、教室、醫院等），是唯一可以兩種體驗都嘗試的場所。',
  },
];
// 实用贴士数据
const tips = [
  {
    text: '晚上 7 點後入場，技師選擇最豐富。大部分技師在下午 1 點陸續上班，到晚上 7 點後基本全部到齊，技師介紹表演也在此時開始。',
  },
  {
    text: '過夜記得帶耳塞和眼罩。桑拿休息區為共享空間（尊貴水療除外），其他客人進出及場內音樂可能影響睡眠，這兩樣小物件能大幅提升過夜舒適度。',
  },
  {
    text: '使用澳門幣現金付款可節省 1-3% 匯率差。信用卡及電子支付會按國際匯率加收手續費，使用澳門幣現金是最經濟的付款方式。可在口岸或酒店 ATM 兌換。',
  },
  {
    text: '輕裝即可——浴袍和拖鞋現場提供。帶手機、錢包、證件就好，其他都可以鎖在儲物櫃裡。大多數客人穿便服進場後直接換上場所的浴袍——沒有著裝要求，不用拎著行李到處走。',
  },
  {
    text: '出發前先詢問我們最新優惠及技師在線情況。各場所不定期推出優惠活動，技師到崗情況每天不同。提前詢問可避免到場後發現心儀類型技師不在的情況。',
  },
  {
    text: '事先告訴我們您偏好的語言。我們會為您配對能夠用英語（或國語、粵語、日語、韓語，視當天情況）流利溝通的場所與技師。和技師清楚溝通對體驗影響很大——也省去新手不少猜測的麻煩。',
  },
  {
    text: '當日來回澳門？24 小時的儲物櫃讓您可以抵達後直接桑拿、再從容離開，全程不用辦理酒店入住。已退房的客人也一樣——把行李安全寄放，享受到出發前一刻。',
  },
];
---

<PageLayout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative min-h-[45vh] flex items-start justify-center overflow-hidden pt-[9.5rem] sm:pt-[12rem]">
    <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-[#0a0a0a]/90 to-[#0a0a0a]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(212,175,55,0.08),transparent_60%)]"></div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pb-12">
      <div class="fade-up">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 tracking-wider">第一次來澳門桑拿？</h1>
      </div>
      <div class="fade-up" style="transition-delay: 0.2s">
        <p class="text-lg text-white/60 mb-8 max-w-2xl mx-auto leading-relaxed">我們幫你安排一切，從接送到場所推薦</p>
      </div>
      <div class="fade-up" style="transition-delay: 0.4s">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`#contact`}
            data-smooth-scroll
            class="px-8 py-3.5 bg-[#D4AF37] hover:bg-[#b8962e] text-black font-semibold rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-[#D4AF37]/20 tracking-wider"
            >立即聯繫我們</a
          >
          <a
            href={`/${lang}/`}
            class="flex items-center gap-2 px-6 py-3 text-white/50 hover:text-[#D4AF37] transition-colors duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-4 h-4"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg
            >
            返回首頁
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect Section -->
  <section class="pb-12 sm:pt-2 sm:pb-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">你可以期待什麼</h2>
        <div class="w-16 h-0.5 bg-gold mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        <div class="bg-[#141414] border border-white/5 rounded-xl p-6 hover:border-gold/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-gold/10 border border-gold/20 flex items-center justify-center mb-4">
            <Icon name="lucide:shield" class="w-6 h-6 text-gold" />
          </div>
          <h3 class="text-lg font-semibold mb-2">安全合法</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            所有正規場所均持有澳門旅遊局發出的「蒸汽浴及按摩場所准照」，與賭場採用相同的政府監管制度。場所定期接受衛生局、消防局及旅遊局的聯合檢查，確保環境衛生及消防安全達標。你可以在澳門旅遊局官網查核任何場所的牌照狀態，完全公開透明。
          </p>
          <a
            href="https://www.dst.gov.mo/zh-hant/public-services/licensed-entities.html?comType=10&ps=20&pn=1"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 mt-4 px-4 py-2 bg-gold/15 hover:bg-gold/25 text-gold font-semibold text-sm rounded-full border border-gold/40 hover:border-gold/60 transition-all"
          >
            到旅遊局官網查詢牌照 <span aria-hidden="true">↗</span>
          </a>
        </div><div
          class="bg-[#141414] border border-white/5 rounded-xl p-6 hover:border-gold/20 transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-xl bg-gold/10 border border-gold/20 flex items-center justify-center mb-4">
            <Icon name="lucide:sparkles" class="w-6 h-6 text-gold" />
          </div>
          <h3 class="text-lg font-semibold mb-2">一站式體驗</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            從踏入場所的一刻起，所有設施均已包含在內：沐浴區設有按摩浴缸、乾蒸及濕蒸桑拿；餐飲區提供免費無限量牛排、海鮮、粵式燉湯、川式精緻小炒、炒飯、新鮮水果及凍啤；娛樂區有技師介紹及互動環節；休息區設有躺椅可過夜。整個體驗可長達
            12-15 小時，一個地方滿足所有需求。
          </p>
        </div><div
          class="bg-[#141414] border border-white/5 rounded-xl p-6 hover:border-gold/20 transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-xl bg-gold/10 border border-gold/20 flex items-center justify-center mb-4">
            <Icon name="lucide:users" class="w-6 h-6 text-gold" />
          </div>
          <h3 class="text-lg font-semibold mb-2">專人安排</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            你無需自行研究、比較或張羅任何事情。告訴我們你的喜好和預算，我們會推薦最適合的場所、安排免費私人專車接送（澳門任何地點）、為你爭取專屬優惠價格，並提前告知技師在線情況及等候時間。自行前往可能需等候1-2小時且價格較高，透過我們預約可完全避免。
          </p>
        </div><div
          class="bg-[#141414] border border-white/5 rounded-xl p-6 hover:border-gold/20 transition-all duration-300"
        >
          <div class="w-12 h-12 rounded-xl bg-gold/10 border border-gold/20 flex items-center justify-center mb-4">
            <Icon name="lucide:gift" class="w-6 h-6 text-gold" />
          </div>
          <h3 class="text-lg font-semibold mb-2">VIP 尊享</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            每筆預約皆贈送 1 項 VIP
            尊享——可任選擦背服務、頭部按摩、足底按摩、修手指甲、修腳指甲、手部按摩、採耳等項目。我們會事先通知場地您的到訪，到場時可直接挑選。再加上
            VIP 優先入場，無需在前台排隊。
          </p>
          <button
            type="button"
            data-open-vip-drawer
            class="inline-flex items-center gap-1.5 mt-4 px-4 py-2 bg-gold/15 hover:bg-gold/25 text-gold font-semibold text-sm rounded-full border border-gold/40 hover:border-gold/60 shadow-[0_0_16px_rgba(212,175,55,0.18)] hover:shadow-[0_0_22px_rgba(212,175,55,0.32)] transition-all cursor-pointer"
          >
            查看全部 8 項 →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Ranking Link Banner -->
  <section class="px-4 pb-4">
    <div class="max-w-4xl mx-auto">
      <a
        href={`/${lang}/ranking/`}
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 bg-[#141414] border border-[#D4AF37]/15 hover:border-[#D4AF37]/40 rounded-xl p-5 transition-all duration-300 group"
      >
        <p class="text-white/65 text-sm leading-relaxed">
          想看 {countSpas} 間場館完整排名——價格、過夜、KTV，以及每次預約免費贈送的按摩護理？
        </p>
        <span
          class="inline-flex items-center gap-1.5 text-[#D4AF37] font-semibold text-sm whitespace-nowrap group-hover:text-[#e5c34a] transition-colors"
        >
          查看全部 {countSpas} 間澳門桑拿排名
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"><path d="m9 18 6-6-6-6"></path></svg
          >
        </span>
      </a>
    </div>
  </section>

  <!-- Full Process Section -->
  <section class="py-12 sm:py-16 px-4 bg-gradient-to-b from-[#0a0a0a] via-[#0f0f0f] to-[#0a0a0a]">
    <div class="max-w-4xl mx-auto">
      <div class="fade-up text-center mb-8 in-view">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">完整流程</h2>
        <div class="w-16 h-0.5 bg-gold mx-auto mb-4"></div>
        <p class="text-white/40 text-sm italic max-w-xl mx-auto">各場所略有不同，聯繫我們了解詳情。</p>
      </div>
      <div class="relative max-w-2xl mx-auto">
        <div class="absolute left-5 top-2 bottom-2 w-px bg-gold/20"></div>
        <div class="space-y-6">
          <div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.00s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">1</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">聯繫我們</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                告訴我們你的喜好（場所風格、預算範圍、技師類別偏好），我們會根據你的需求推薦最適合的場所。我們熟悉每間場所的特色及最新動態，能為你做出最精準的配對。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.04s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">2</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">免費接送</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                確認場所後，我們安排七人座私人專車（Alphard／奔馳）到你指定的地點接你，澳門任何酒店或位置均可。全程免費，無需自行搭的士或找路，輕鬆抵達。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.08s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">3</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">抵達入場</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                到達後在前台登記，領取手牌及儲物櫃鑰匙，前往更衣室換上浴袍並寄存行李。所有場所均提供免費安全儲物櫃，無需擔心個人物品。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.12s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">4</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">沐浴放鬆</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                先花20-30分鐘享用按摩浴缸、乾蒸及濕蒸桑拿，讓身體放鬆下來。這是調整狀態的重要一步，也是體驗的一部分——不要急，慢慢享受。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.16s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">5</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">免費用餐</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                所有場所均提供免費無限量餐飲，包括精選牛排、新鮮海鮮、粵式燉湯、川式精緻小炒、炒飯、炒麵、新鮮水果、凍啤酒及各式飲品。全程免費供應，無需額外付費。部分場所的招牌牛排、海鮮拼盤及老火靚湯特別出名，值得細嚐。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.20s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">6</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">走秀環節</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                這是最精彩的環節——技師們會在大廳走秀介紹，你可以近距離觀賞後選擇心儀的技師。每間場所的形式不同：壹號桑拿有
                140+ 人大型走秀、十八桑拿有池邊長龍、帝湖有舞台介紹。技師介紹通常在晚上 7 點後開始，氣氛最為熱烈。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.24s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">7</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">60分鐘服務</h3>
              <p class="text-white/50 text-sm leading-relaxed">
                選擇技師後進入獨立房間，享受 60
                分鐘的一對一專屬服務。服務內容視場所及技師類別而定，可包括按摩、水床體驗或主題情境體驗。全程在私密空間內進行。
              </p>
            </div>
          </div><div class="fade-up relative flex gap-5 items-start in-view" style="transition-delay:0.28s">
            <div
              class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-gold/15 border border-gold/30 flex items-center justify-center"
            >
              <span class="text-gold font-bold text-sm">8</span>
            </div>
            <div class="pt-1.5 pb-2">
              <h3 class="font-semibold text-base mb-1">休息過夜</h3>

---
import { getCollection } from 'astro:content';
import { getAsset } from '~/utils/permalinks';

interface Props {
  currentSlug: string;
  lang: string;
  title?: string;
  count?: number;
}

const { currentSlug, lang, title = '其他熱門會所', count = 4 } = Astro.props;

// 获取所有 spa 数据
const allSpas = await getCollection('spa');

// 过滤掉当前会所，只保留同语言的（通过 slug 匹配 zh-TW 目录下的文件）
const otherSpas = allSpas.filter(spa => spa.data.slug !== currentSlug);

// 随机打乱并取前 count 个
const shuffled = [...otherSpas].sort(() => Math.random() - 0.5);
const selectedSpas = shuffled.slice(0, count);
---

{selectedSpas.length > 0 && (
  <div class="fade-up mb-16">
    <h2 class="text-xl font-semibold mb-6 text-gold">{title}</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {selectedSpas.map((spa, index) => {
        const { data } = spa;
        // 从 markdown body 中提取描述（取前100字符作为摘要）
        const description = data.seoDescription || '';
        const truncatedDesc = description.length > 80 
          ? description.substring(0, 80) + '...' 
          : description;
        
        return (
          <div 
            class="fade-up" 
            style={`transition-delay: ${(index * 0.03).toFixed(2)}s`}
            data-testid="spa-card"
          >
            <a 
              href={`/${lang}/spa/${data.slug}/`} 
              class="group block bg-[#141414] rounded-2xl overflow-hidden transition-all duration-500 shadow-lg hover:shadow-gold/5 border-white/5 hover:border-gold/30"
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <img 
                  src={getAsset(data.cover)} 
                  alt={`${data.name} — 澳門頂級桑拿會所`} 
                  loading="lazy" 
                  decoding="async" 
                  width="800" 
                  height="600" 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"></div>
              </div>
              <div class="p-5">
                <h3 class="text-lg font-semibold text-white group-hover:text-gold transition-colors duration-300 mb-2">
                  {data.name}
                </h3>
                <p class="text-white/50 text-sm leading-relaxed line-clamp-2">
                  {truncatedDesc}
                </p>
                <div class="mt-4 flex items-center text-gold text-sm font-medium opacity-70 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300">
                  <span>了解更多</span>
                  <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
                </div>
              </div>
            </a>
          </div>
        );
      })}
    </div>
  </div>
)}

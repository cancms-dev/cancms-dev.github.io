// 导入国际化函数
import { t } from '~/i18n';
import { getCollection } from 'astro:content';
// import FeaturedSpas from '~/components/home/FeaturedSpas.astro';
import FeaturedSpas from '~/components/islands/FeaturedSpas.tsx';
import VipTreats from '~/components/home/VipTreats.astro';   // ✅ 已导入
import QuickMatch from '~/components/home/QuickMatch.astro';
import WhyUs from '~/components/home/WhyUs.astro';
import LatestBlogs from '~/components/home/LatestBlogs.astro';
import Testimonials from '~/components/home/Testimonials.astro';
import Contact from '~/components/home/Contact.astro';

// 必须导出 getStaticPaths 函数，以便 Astro 知道要生成哪些路径
export async function getStaticPaths() {
  const supportedLanguages = ['zh-TW'];
  const spas = await getCollection('spa');
  
  return supportedLanguages.map((lang) => ({
    params: { lang },
    props: { lang, spas },
  }));
}

const { lang } = Astro.params;
const { spas } = Astro.props;

const metadata = {
  title: t('hero.title', lang) || '澳門桑拿．您的VIP體驗',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    title={t('hero.title', lang) || '澳門桑拿．您的VIP體驗'}
    subtitle={t('hero.subtitle', lang) || '24小時免費專車接送・送您去・接您回'}
    tagline={t('hero.tagline', lang) || '慶賀新店開業·7月起所有店預約即送小工'}
    imageSrc="/images/hero-bg.jpg"
    imageAlt={t('hero.imageAlt', lang) || '澳門桑拿禮賓服務 — 澳門夜景天際線・VIP 預約・豪華專車接送'}
    actions={[
      {
        variant: 'primary',
        text: t('hero.explore', lang) || '探索會所',
        href: '#spas',
        icon: true,
      },
      {
        variant: 'secondary',
        text: t('hero.book', lang) || '立即預約',
        href: '#contact',
      },
    ]}
  />

  <section id="spas" class="py-20 sm:py-28 px-4 scroll-mt-6"> 
      <FeaturedSpas spas={spas} client:only="react"  />
  </section>


   <VipTreats lang={lang} />       <!-- ✅ 服务流程，放在 FeaturedSpas 后面 -->

  <div class="pb-5 sm:pb-10">
   <QuickMatch lang={lang} />
</div>

  <WhyUs lang={lang} />
  <Testimonials lang={lang} />
  <LatestBlogs lang={lang} />
  <Contact lang={lang} />

  <!-- Note Widget ******************* -->


---
interface Props {
  lang: string;
}

const { lang } = Astro.props as Props;

const contactInfo = {
  phone: '+853 1234 5678',
  email: 'info@relaxmacau.com',
  hours: '24/7 全年無休',
};

const recommendations = [
  {
    icon: 'users',
    title: '朋友同行',
    desc: '多間會所提供同行優惠，二人或以上更划算',
  },
  {
    icon: 'sparkles',
    title: '首訪推薦',
    desc: '新手友善會所，專人指導流程，安心體驗',
  },
  {
    icon: 'clock',
    title: '深夜服務',
    desc: '24小時營業會所，凌晨時段仍有專車接送',
  },
];

const philosophy = {
  title: '我們不只是提供服務，我們真心在乎您的快樂。',
  description: '從您聯繫我們的那一刻起，我們就致力於為您打造最完美的桑拿體驗。我們深知，每一次的選擇都關乎您的感受與信任。因此，我們用心篩選每一家合作會所，確保環境、服務、品質都經得起考驗。我們所做的這一切，就是為了讓您的桑拿體驗成為您從澳門帶回去最美好的回憶之一。',
};
---

<!-- 不知道选哪间？让我们帮你推荐 -->
<section class="pb-12 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">不知道選哪間？讓我們幫你推薦</h2>
      <div class="w-16 h-0.5 bg-gold mx-auto"></div>
      <p class="mt-4 text-white/60 text-sm">
        告訴我們您的需求，我們會為您精選最適合的會所
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {
        recommendations.map((item, index) => (
          <div class="bg-[#141414] border border-white/5 rounded-xl p-6 text-center hover:border-gold/40 transition-colors">
            <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-gold/10 flex items-center justify-center">
              {
                item.icon === 'users' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-gold"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                )
              }
              {
                item.icon === 'sparkles' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-gold"><path d="M6 3v18"/><path d="M6 3 3 6"/><path d="M6 21 3 18"/><path d="M18 3v18"/><path d="M18 3 21 6"/><path d="M18 21 21 18"/></svg>
                )
              }
              {
                item.icon === 'clock' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-gold"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                )
              }
            </div>
            <h3 class="text-base font-semibold mb-2">{item.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-8 text-center">
      <a
        href={`/${lang}/contact`}
        class="inline-block bg-gold hover:bg-gold-dark text-black font-semibold px-8 py-3 rounded-full transition-colors text-sm"
      >
        立即諮詢
      </a>
    </div>
  </div>
</section>

<!-- 联系我们 -->
<section id="contact" class="pt-14 pb-20 sm:pt-20 sm:pb-28 px-4 scroll-mt-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">聯繫我們</h2>
      <div class="w-16 h-0.5 bg-gold mx-auto"></div>
      <p class="mt-4 text-white/60 text-sm">
        有任何問題？隨時聯繫我們，我們將竭誠為您服務
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-1">電話</h4>
            <p class="text-white/60 text-sm">{contactInfo.phone}</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-1">電郵</h4>
            <p class="text-white/60 text-sm">{contactInfo.email}</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-1">服務時間</h4>
            <p class="text-white/60 text-sm">{contactInfo.hours}</p>
          </div>
        </div>

        <div class="pt-4">
          <a
            href={`/${lang}/contact`}
            class="inline-block bg-gold hover:bg-gold-dark text-black font-semibold px-6 py-2.5 rounded-full transition-colors text-sm"
          >
            發送訊息
          </a>
        </div>
      </div>

      <div class="bg-[#141414] border border-white/5 rounded-xl p-6">
        <h4 class="text-sm font-semibold mb-4">快速聯繫</h4>
        <p class="text-white/50 text-sm leading-relaxed mb-4">
          您也可以透過以下方式直接聯繫我們，我們將在最短時間內回覆。
        </p>
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-sm">
            <span class="text-gold">微信：</span>
            <span class="text-white/60">AN99348</span>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <span class="text-gold">WhatsApp：</span>
            <span class="text-white/60">{contactInfo.phone}</span>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <span class="text-gold">Telegram：</span>
            <span class="text-white/60">@relaxmacau</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 我们不只是提供服务，我们真心在乎您的快乐 -->
<section class="pb-12 sm:pb-16 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="bg-[#141414] border border-white/5 rounded-2xl p-8 text-center">
      <div class="w-16 h-0.5 bg-gold mx-auto mb-6"></div>
      <h3 class="text-xl sm:text-2xl font-bold mb-4">{philosophy.title}</h3>
      <p class="text-white/60 text-sm leading-relaxed">{philosophy.description}</p>
    </div>
  </div>
</section>

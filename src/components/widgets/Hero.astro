---
import type { CallToAction } from '~/types';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  actions?: CallToAction[];
  images?: Array<{ src: string; alt: string }>;
}

const {
  title = '澳門桑拿．您的VIP體驗',
  subtitle = '24小時免費專車接送・送您去・接您回',
  tagline = '慶賀新店開業·7月起所有店預約即送小工',
  actions = [],
  images = [
    { src: '/images/macau-sauna-night-skyline.jpg', alt: '澳門桑拿禮賓服務 — 澳門夜景天際線・VIP 預約・豪華專車接送' },
    { src: '/images/macau-sauna-cotai-casino-skyline-night.jpg', alt: '澳門桑拿 VIP 禮賓服務 — 路氹賭場夜景・豪華專車接送' },
    { src: '/images/macau-sauna-tower-fireworks-night.webp', alt: '旅客專屬澳門桑拿禮賓服務 — 澳門旅遊塔煙花夜景' },
  ],
} = Astro.props;

// 确保至少有一张图片
const bgImages = images.length > 0 ? images : [{ src: '/images/hero-bg.jpg', alt: '背景图片' }];
---

<section class="relative min-h-screen flex items-start justify-center overflow-hidden pt-[9.5rem] sm:pt-[12rem] pb-12 sm:pb-16">
  <!-- 背景图片容器 - 多图循环 -->
  <div class="absolute inset-0 bg-hero-container">
    {bgImages.map((img, index) => (
      <div 
        key={index}
        class="absolute inset-0 bg-hero-item"
        data-index={index}
        style={{
          opacity: index === 0 ? 1 : 0,
          transform: 'scale(1.08)',
          transition: 'opacity 1.5s ease-in-out, transform 2.5s ease-in-out',
        }}
      >
        <img 
          src={img.src}
          alt={img.alt}
          width="1920" 
          height="1080" 
          fetchPriority={index === 0 ? 'high' : 'low'}
          decoding="async"
          loading={index === 0 ? 'eager' : 'lazy'}
          class="w-full h-full object-cover object-center"
        />
      </div>
    ))}
  </div>

  <!-- 渐变遮罩 -->
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/60 to-[#0a0a0a]"></div>

  <!-- 内容容器 -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <!-- Tagline 标签 -->
    <!-- {tagline && (
      <div class="inline-block bg-green-500/15 text-green-400 text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">
        {tagline}
      </div>
    )} -->

    <!-- 主标题 -->
    <h1 class="text-[28px] sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
      {title}
    </h1>
    
    <!-- 副标题 -->
    <p class="text-white/70 text-sm sm:text-lg md:text-xl max-w-3xl mx-auto mb-6">
      {subtitle}
    </p>

    <!-- 步骤图标行 -->
    <div data-testid="hero-icon-row" class="flex items-start justify-center gap-3 sm:gap-6 mb-8">
      <!-- 步骤 1 -->
      <div class="flex flex-col items-center gap-1" data-step="1" style="opacity:0;transform:translateY(15px)">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-gold/50 border border-gold/50 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle w-6 h-6 text-gold" aria-hidden="true">
            <path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"></path>
          </svg>
        </div>
        <span class="text-white font-semibold text-sm sm:text-base whitespace-nowrap">立即聯繫</span>
        <span class="text-xs sm:text-sm text-center">
          <span class="text-gold font-bold">一切交給</span><br/>
          <span class="text-gold font-bold">我們安排</span>
        </span>
      </div>

      <!-- 箭头 1 -->
      <span class="text-gold text-xl sm:text-2xl font-black self-start mt-2 sm:mt-3" data-step-arrow="1" style="opacity:0;transform:translateX(-10px)">→</span>

      <!-- 步骤 2 -->
      <div class="flex flex-col items-center gap-1" data-step="2" style="opacity:0;transform:translateY(15px)">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-gold/50 border border-gold/50 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-car w-6 h-6 text-gold" aria-hidden="true">
            <path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path>
            <circle cx="7" cy="17" r="2"></circle>
            <path d="M9 17h6"></path>
            <circle cx="17" cy="17" r="2"></circle>
          </svg>
        </div>
        <span class="text-white font-semibold text-sm sm:text-base whitespace-nowrap">免費專車接送</span>
        <span class="text-xs sm:text-sm text-center">
          <span class="text-white/80">隨時隨地</span><br/>
          <span class="text-white/80">全澳接送</span>
        </span>
      </div>

      <!-- 箭头 2 -->
      <span class="text-gold text-xl sm:text-2xl font-black self-start mt-2 sm:mt-3" data-step-arrow="2" style="opacity:0;transform:translateX(-10px)">→</span>

      <!-- 步骤 3 -->
      <div class="flex flex-col items-center gap-1" data-step="3" style="opacity:0;transform:translateY(15px)">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-gold/50 border border-gold/50 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-crown w-6 h-6 text-gold" aria-hidden="true">
            <path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"></path>
            <path d="M5 21h14"></path>
          </svg>
        </div>
        <span class="text-white font-semibold text-sm sm:text-base whitespace-nowrap">您只管享受</span>
        <span class="text-xs sm:text-sm text-center">
          <span class="text-gold font-bold">VIP 尊享</span><br/>
          <span class="text-white/80">優先入場</span>
        </span>
      </div>
    </div>

    <!-- 按钮组 -->
    <div class="flex flex-wrap items-center justify-center gap-3">
      {actions.map((action, index) => (
        <a 
          key={index}
          href={action.href || '#'}
          target={action.target || '_self'}
          class={[
            'inline-flex items-center gap-2 px-6 py-3 rounded-full font-semibold text-sm transition-all duration-300',
            action.variant === 'primary' 
              ? 'bg-gold hover:bg-gold-dark text-black shadow-lg hover:shadow-gold/30' 
              : 'border border-white/30 hover:border-white/60 text-white hover:bg-white/10'
          ].filter(Boolean).join(' ')}
        >
          {action.icon && (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
          )}
          {action.text}
        </a>
      ))}
    </div>
  </div>
</section>

<!-- 客户端脚本：背景图轮播 + 步骤入场动画 -->
<script>
  (function() {
    // ===== 1. 背景图轮播 =====
    const bgItems = document.querySelectorAll('.bg-hero-item');
    const total = bgItems.length;
    if (total > 1) {
      let current = 0;
      let intervalId = null;
      let isTransitioning = false;

      function showNext() {
        if (isTransitioning) return;
        isTransitioning = true;
        const next = (current + 1) % total;
        
        // 当前图片淡出 + 缩小
        bgItems[current].style.opacity = '0';
        bgItems[current].style.transform = 'scale(1.04)';
        
        // 下一张图片淡入 + 放大
        bgItems[next].style.opacity = '1';
        bgItems[next].style.transform = 'scale(1.08)';
        
        current = next;
        
        // 过渡完成后解锁
        setTimeout(() => {
          isTransitioning = false;
        }, 1600);
      }

      // 初始化：所有图片从 scale(1.04) 开始
      bgItems.forEach((item, idx) => {
        item.style.transform = 'scale(1.04)';
        // 当前可见图片立即开始缓慢放大到 1.08
        if (idx === 0) {
          requestAnimationFrame(() => {
            item.style.transform = 'scale(1.08)';
          });
        }
      });

      // 开始轮播（每5秒切换一次）
      function startCarousel() {
        if (intervalId) clearInterval(intervalId);
        intervalId = setInterval(showNext, 5000);
      }

      function stopCarousel() {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      }

      // 页面可见性变化时控制轮播
      document.addEventListener('visibilitychange', function() {
        if (document.hidden) {
          stopCarousel();
        } else {
          startCarousel();
        }
      });

      // 开始轮播
      startCarousel();
    }

    // ===== 2. 步骤入场动画 =====
    const steps = document.querySelectorAll('[data-step]');
    const arrows = document.querySelectorAll('[data-step-arrow]');
    const allItems = [...steps, ...arrows];
    
    if (allItems.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // 延迟依次出现
            const delay = Array.from(allItems).indexOf(entry.target) * 80;
            setTimeout(() => {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
              if (entry.target.hasAttribute('data-step-arrow')) {
                entry.target.style.transform = 'translateX(0)';
              }
            }, delay);
          }
        });
      }, { threshold: 0.2 });

      allItems.forEach(item => observer.observe(item));
    }
  })();
</script>

<style is:global>
  /* 金色主题颜色 */
  .text-gold { color: #d4af37; }
  .border-gold { border-color: #d4af37; }
  .bg-gold { background-color: #d4af37; }
  .bg-gold\/50 { background-color: rgba(212, 175, 55, 0.5); }
  .border-gold\/50 { border-color: rgba(212, 175, 55, 0.5); }
  .hover\:bg-gold-dark:hover { background-color: #b8962e; }
  .hover\:shadow-gold\/30:hover { box-shadow: 0 0 30px rgba(212, 175, 55, 0.3); }
  
  /* 过渡动画 */
  [data-step], [data-step-arrow] {
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

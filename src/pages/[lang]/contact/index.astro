---
import PageLayout from '~/layouts/PageLayout.astro';
import ContactSection from '~/components/islands/ContactSection.astro';

export async function getStaticPaths() {
  const languages = ['zh-TW', 'zh-CN', 'en', 'ja'];
  return languages.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;

const metadata = {
  title: '聯絡我們｜澳門桑拿預約站',
  description: '想預約澳門桑拿、查詢價格或安排免費接送？任選下方任一通訊軟體傳訊給我們，我們以繁中、簡中、英文及廣東話為您即時服務。',
};
---

<PageLayout metadata={metadata}>
  <!-- Hero Section -->
  <section class="pt-[9.5rem] sm:pt-[12rem] pb-10 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="fade-up">
        <p class="text-[0.7rem] sm:text-xs uppercase tracking-[0.3em] text-[#D4AF37]/90 font-semibold mb-4">隨時為您安排</p>
        <h1 class="text-3xl sm:text-5xl font-bold mb-6 leading-tight">聯絡我們</h1>
        <p class="text-white/70 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">想預約澳門桑拿、查詢價格或安排免費接送？任選下方任一通訊軟體傳訊給我們，我們以繁中、簡中、英文及廣東話為您即時服務。</p>
        <div class="mt-6">
          <a href={`/${lang}/`} class="inline-flex items-center text-white/40 hover:text-[#D4AF37] transition-colors text-sm group">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 mr-2 transition-transform group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
            返回首頁
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Channels Section -->
  <h2 class="text-center text-xl sm:text-2xl font-bold mb-6">選擇您方便的聯絡方式</h2>
  <ContactSection lang={lang}  />

  <!-- Service Highlights Section -->
  <section class="pb-12 px-4">
    <div class="max-w-4xl mx-auto grid gap-5 sm:grid-cols-3">
      <div class="fade-up">
        <div class="h-full rounded-2xl border border-white/5 bg-[#141414] hover:border-[#D4AF37]/30 transition-colors p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-[#D4AF37]/10 border border-[#D4AF37]/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-[#D4AF37]"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
          </div>
          <h3 class="font-bold mb-2">24 小時快速回覆</h3>
          <p class="text-white/60 text-sm leading-relaxed">日夜皆有專人接訊，通常數分鐘內回覆，協助您即時預約。</p>
        </div>
      </div>
      <div class="fade-up">
        <div class="h-full rounded-2xl border border-white/5 bg-[#141414] hover:border-[#D4AF37]/30 transition-colors p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-[#D4AF37]/10 border border-[#D4AF37]/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-[#D4AF37]"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path><circle cx="7" cy="17" r="2"></circle><path d="M9 17h6"></path><circle cx="17" cy="17" r="2"></circle></svg>
          </div>
          <h3 class="font-bold mb-2">免費名車接送</h3>
          <p class="text-white/60 text-sm leading-relaxed">從酒店、口岸、機場免費接您出發，並以名車禮遇送您回程；回程請預約時提前告知。</p>
        </div>
      </div>
      <div class="fade-up">
        <div class="h-full rounded-2xl border border-white/5 bg-[#141414] hover:border-[#D4AF37]/30 transition-colors p-6 text-center">
          <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-[#D4AF37]/10 border border-[#D4AF37]/20 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-[#D4AF37]"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"></path></svg>
          </div>
          <h3 class="font-bold mb-2">完全免費・無中介費</h3>
          <p class="text-white/60 text-sm leading-relaxed">我們的預約與諮詢服務完全免費，價格與場館直接收費一致。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Tell Us & Privacy Section -->
  <section class="pb-12 px-4">
    <div class="max-w-4xl mx-auto grid gap-6 md:grid-cols-2">
      <div class="fade-up">
        <div class="h-full rounded-2xl border border-[#D4AF37]/10 bg-white/[0.02] p-6 sm:p-8">
          <h2 class="text-xl sm:text-2xl font-bold mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-[#D4AF37]"><path d="M13 5h8"></path><path d="M13 12h8"></path><path d="M13 19h8"></path><path d="m3 17 2 2 4-4"></path><path d="m3 7 2 2 4-4"></path></svg>
            傳訊時告訴我們
          </h2>
          <p class="text-white/60 text-sm mb-4">第一則訊息附上以下資訊，我們即可一次為您安排妥當：</p>
          <ul class="space-y-2.5">
            <li class="flex gap-2.5 text-white/75 text-sm leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#D4AF37] shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>想去的會所（或告訴我們喜好，由我們為您推薦）</span>
            </li>
            <li class="flex gap-2.5 text-white/75 text-sm leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#D4AF37] shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>想前往的日期與時間</span>
            </li>
            <li class="flex gap-2.5 text-white/75 text-sm leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#D4AF37] shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>人數</span>
            </li>
            <li class="flex gap-2.5 text-white/75 text-sm leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#D4AF37] shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>接送地點（酒店、口岸或機場）</span>
            </li>
            <li class="flex gap-2.5 text-white/75 text-sm leading-relaxed">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[#D4AF37] shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"></path></svg>
              <span>偏好語言與預算範圍</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="fade-up">
        <div class="h-full rounded-2xl border border-[#D4AF37]/10 bg-white/[0.02] p-6 sm:p-8 flex flex-col justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 text-[#D4AF37] mb-3"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
          <h2 class="text-xl sm:text-2xl font-bold mb-3">完全保密・安心預約</h2>
          <p class="text-white/65 text-sm leading-relaxed">我們重視您的隱私。您提供的資料僅用於安排預約與接送，絕不外洩或用於其他用途。詳見我們的隱私政策。</p>
          <a href={`/${lang}/privacy/`} class="inline-flex items-center text-[#D4AF37] hover:underline text-sm mt-3">隱私政策 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="pb-12 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="fade-up">
        <h2 class="text-xl sm:text-2xl font-bold mb-6 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-[#D4AF37]"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path></svg>
          聯絡我們・常見問題
        </h2>
        <div class="space-y-3">
          <details open class="group rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-5 py-4 hover:border-[#D4AF37]/20 transition-colors">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-white/85 list-none">
              多快會回覆？
              <span class="text-[#D4AF37] text-lg leading-none shrink-0 transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="text-white/60 text-sm leading-relaxed mt-3">通常數分鐘內回覆，24 小時皆有專人服務。</p>
          </details>
          <details class="group rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-5 py-4 hover:border-[#D4AF37]/20 transition-colors">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-white/85 list-none">
              預約需要收費嗎？
              <span class="text-[#D4AF37] text-lg leading-none shrink-0 transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="text-white/60 text-sm leading-relaxed mt-3">不需要。我們的禮賓預約服務完全免費，費用一律於現場直接支付，與場館自身收費相同。</p>
          </details>
          <details class="group rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-5 py-4 hover:border-[#D4AF37]/20 transition-colors">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-white/85 list-none">
              查詢是否保密？
              <span class="text-[#D4AF37] text-lg leading-none shrink-0 transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="text-white/60 text-sm leading-relaxed mt-3">是。我們嚴格保護您的隱私，資料僅用於安排您的預約與接送。</p>
          </details>
          <details class="group rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-5 py-4 hover:border-[#D4AF37]/20 transition-colors">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-white/85 list-none">
              應該用哪個通訊軟體？
              <span class="text-[#D4AF37] text-lg leading-none shrink-0 transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="text-white/60 text-sm leading-relaxed mt-3">任選即可——WhatsApp、WeChat、Line 與 Telegram 都由同一團隊即時為您服務。</p>
          </details>
          <details class="group rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-5 py-4 hover:border-[#D4AF37]/20 transition-colors">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-white/85 list-none">
              可以用英文或廣東話溝通嗎？
              <span class="text-[#D4AF37] text-lg leading-none shrink-0 transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="text-white/60 text-sm leading-relaxed mt-3">可以。我們提供繁體中文、簡體中文、英文與廣東話服務。</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Links Section -->
  <section class="pb-16 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="fade-up">
        <h2 class="text-center text-lg font-bold mb-5 text-white/70">預約前不妨先看</h2>
        <div class="grid gap-3 sm:grid-cols-3">
          <a href={`/${lang}/ranking/`} class="flex items-center justify-between rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-4 py-3 text-sm text-white/75 hover:text-[#D4AF37] hover:border-[#D4AF37]/30 transition-colors">
            <span>12 間桑拿排名與價格</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
          <a href={`/${lang}/guide/`} class="flex items-center justify-between rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-4 py-3 text-sm text-white/75 hover:text-[#D4AF37] hover:border-[#D4AF37]/30 transition-colors">
            <span>第一次來？看新手指南</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
          <a href={`/${lang}/shuttle/`} class="flex items-center justify-between rounded-xl border border-[#D4AF37]/10 bg-white/[0.02] px-4 py-3 text-sm text-white/75 hover:text-[#D4AF37] hover:border-[#D4AF37]/30 transition-colors">
            <span>免費名車接送服務</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 shrink-0"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Fade-up Animation Script -->

  <!-- 在 <script> 标签上添加 data-astro-rerun 属性，Astro 会在每次页面切换后重新执行该脚本 -->
<script type="module" data-astro-rerun>
  setTimeout(() => {
    document.querySelectorAll('.fade-up:not(.in-view)').forEach((el) => el.classList.add('in-view'));
  }, 200);
</script>
</PageLayout>

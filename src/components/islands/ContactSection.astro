---
import { getAsset } from '~/utils/permalinks';
import ModalWechat from '~/components/common/ModalWechat.astro';

export interface Props {
  lang?: string;
  message?: string;
  class?: string;
}

const { lang = 'zh-TW', message = '你好，我想預約澳門桑拿，可以安排嗎？', class: className = '' } = Astro.props as Props;


// 联系渠道配置
const channels = [
  {
    name: 'WhatsApp',
    href: `https://wa.me/85365670348?text=${message}`,
    icon: getAsset('images/whatsapp.svg'),
    description: '立即聯繫',
    type: 'link'
  },
  {
    name: 'Telegram',
    href: `https://t.me/Aomensauna?text=${message}`,
    icon: getAsset('images/telegram.svg'),
    description: '@Aomensauna',
    type: 'link'
  },
  {
    name: 'WeChat',
    href: '#',
    icon: getAsset('images/wechat.svg'),
    description: 'AN99348',
    type: 'wechat'
  },
  {
    name: 'LINE',
    href: 'https://line.me/ti/p/VZHFDSZnq9',
    icon: getAsset('images/line.svg'),
    description: '16880348',
    type: 'link'
  }
];

const weChatQrCode = getAsset('images/wechat-qr.png');
const wechatId = 'AN99348';

---

<!-- 联系我们 -->
<section id="contact" class="pt-2 pb-2 sm:pt-8 sm:pb-8 px-4 scroll-mt-6">
  <div class="max-w-4xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        {channels.map((ch) => (
          ch.type === 'wechat' ? (
            <button
              type="button"
              data-wechat-trigger="true"
              class="flex items-center gap-4 bg-[#141414] border border-white/5 hover:border-gold/30 rounded-xl p-2.5 transition-all duration-300 group text-left w-full"
            >
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors">
                <img src={ch.icon} alt={ch.name} class="w-7 h-7 rounded-md" />
              </div>
              <div>
                <div class="text-white/40 text-xs mb-1">{ch.name}</div>
                <div class="text-white font-medium">{ch.description}</div>
              </div>
            </button>
          ) : (
            <a
              href={`${ch.href}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-4 bg-[#141414] border border-white/5 hover:border-gold/30 rounded-xl p-2.5 transition-all duration-300 group text-left w-full"
            >
              <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors">
                <img src={ch.icon} alt={ch.name} class="w-7 h-7 rounded-md" />
              </div>
              <div>
                <div class="text-white/40 text-xs mb-1">{ch.name}</div>
                <div class="text-white font-medium">{ch.description}</div>
              </div>
            </a>
          )
        ))}
 
    </div>
  </div>
</section>

<ModalWechat qrCodeSrc={weChatQrCode} wechatId={wechatId} />

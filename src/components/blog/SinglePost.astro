---
import { Icon } from 'astro-icon/components';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';

import { getPermalink, langLink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';
import ContactSection from '~/components/islands/ContactSection.astro';

// 从 Markdown 内容中提取 h2 标题
function extractHeadings(content: any): { text: string; id: string }[] {
  if (!content) return [];
  // 如果是 Astro 组件，无法直接解析，返回空数组
  // 实际项目中建议使用 remark 插件在构建时提取
  return [];
}


export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;

// console.log('SinglePost post:', post);

---

<article class="pt-[8.5rem]  min-h-screen bg-[#0a0a0a]" >
  <div class="relative h-[42vh] min-h-[260px] w-full overflow-hidden" >
     {post.coverImage && (
          <img
            src={post.coverImage}
            alt={post.title || ''}
            class="absolute inset-0 w-full h-full object-cover"
          />
      )} 
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/55 to-black/20" ></div>
    <div class="absolute bottom-0 left-0 right-0 px-4 pb-7" >
      <div class="max-w-2xl mx-auto" >
        <span class="text-gold text-xs font-bold uppercase tracking-[0.12em]" >{post.category?.title || '文章'}</span>
        <h1 class="mt-2 text-2xl sm:text-4xl font-bold leading-tight" >
          {post.title}
        </h1>
        <p class="mt-3 text-xs sm:text-sm text-white/60" >
          {post.author || 'Relax Macau Team'} · {getFormattedDate(post.publishDate)} · {post.readingTime || 1} 分鐘
        </p>
      </div>
    </div>
  </div>
  <div class="max-w-2xl mx-auto px-4 py-10" >
    <a
      href={langLink('blog')}
      class="inline-flex items-center gap-2 text-white/50 hover:text-gold transition-colors mb-8 text-sm"
       
    >
      <Icon name="lucide:arrow-left" class="w-4 h-4"   /> 所有文章
    </a>
    <nav class="bg-[#161616] border border-white/10 rounded-xl px-5 py-4 mb-8" >
      <p class="text-gold text-[11px] font-bold uppercase tracking-[0.12em] mb-2"  >
        本文重點
      </p>
      <ul class="space-y-1.5"  >
        {post.headings && post.headings.length > 0 ? (
          post.headings.map((heading) => (
            <li >
              <a
                href={`#${heading.id}`}
                class="text-white/70 hover:text-gold text-sm transition-colors"
                
              >
                {heading.text}
              </a>
            </li>
          ))
        ) : (
          <li  >
            <span class="text-white/40 text-sm">暫無目錄</span>
          </li>
        )}
      </ul>
    </nav>
    <div class="prose-blog">
      {post.Content ? <post.Content /> : <p>文章內容加載中...</p>}
    </div>
    <div
      class="bg-gradient-to-br from-[#1a1505] to-[#241c08] border border-gold/40 rounded-2xl p-6 my-10 text-center"
      
    >
      <h2 class="text-gold text-lg font-bold mb-2"  >準備預約？</h2>
      <p class="text-white/60 text-sm mb-5" >
        免費私人七人座專車，澳門與氹仔皆可接送。聯絡我們安排。
      </p>

      <ContactSection   />

    </div>

    <RelatedPosts post={post} />
   
  </div>
</article>


<style is:global>
            .prose-blog p {
                color: #dcdcdc;
                line-height: 1.85;
                margin: 0 0 1rem;
                font-size: .95rem
            }

            .prose-blog h2 {
                font-size: 1.15rem;
                font-weight: 700;
                margin: 1.75rem 0 .75rem;
                padding-left: .6rem;
                border-left: 3px solid #D4AF37;
                scroll-margin-top: 5rem
            }

            .prose-blog h3 {
                font-size: 1rem;
                font-weight: 700;
                margin: 1.25rem 0 .5rem
            }

            .prose-blog ul {
                margin: 0 0 1rem;
                padding-left: 1.25rem;
                list-style: disc
            }

            .prose-blog li {
                color: #dcdcdc;
                line-height: 1.8;
                margin: .25rem 0
            }

            .prose-blog a {
                color: #d4af37;
                text-decoration: underline;
                text-underline-offset: 2px
            }

            .prose-blog strong {
                color: #f5f5f5
            }

            .prose-blog img {
                border-radius: .6rem;
                margin: 1rem 0;
                width: 100%;
                height: auto
            }

            .prose-blog table {
                width: 100%;
                border-collapse: collapse;
                margin: 1rem 0;
                font-size: .85rem
            }

            .prose-blog th {
                text-align: left;
                color: #d4af37;
                border-bottom: 1px solid #C5A028;
                padding: .5rem
            }

            .prose-blog td {
                border-bottom: 1px solid #262626;
                padding: .5rem;
                color: #ccc
            }
        </style>

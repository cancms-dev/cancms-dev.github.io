---
import { Icon } from 'astro-icon/components';

interface Props {
  lang: string;
}

const { lang } = Astro.props as Props;

// 特性数据
const features = [
  {
    icon: 'crown',
    title: '技師走秀',
    desc: '現場親眼觀賞，自選心儀技師，全澳最豐富選擇',
  },
  {
    icon: 'shield',
    title: '舒適專屬私密服務',
    desc: '獨立房間一對一，全程私密、毫無干擾',
  },
  
  {
    icon: 'sparkles',
    title: '主題場景房',
    desc: '20+ 款主題場景，可自訂情境體驗',
  },
  {
    icon: 'clock',
    title: '可過夜不加價',
    desc: '12-15 小時自由停留，含早餐與洗浴',
  },
];
---
 

<section
  id="whyus"
  class="pt-14 pb-20 sm:pt-20 sm:pb-28 px-4 scroll-mt-6 bg-gradient-to-b from-[#0a0a0a] via-[#0f0f0f] to-[#0a0a0a]"
>
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">為何選擇我們</h2>
      <div class="w-20 h-0.5 bg-gold mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        features.map((feature, index) => (
          <div class="text-center group" style={`transition-delay:${index * 0.03}s`}>
            <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gold/10 border border-gold/20 flex items-center justify-center group-hover:bg-gold/20 group-hover:border-gold/40 transition-all duration-500">
              <Icon name={`lucide:${feature.icon}`} class="w-7 h-7 text-gold" />
            </div>
            <h3 class="text-lg font-semibold mb-3">{feature.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{feature.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

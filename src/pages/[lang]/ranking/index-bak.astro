  { icon: '🦵', name: '腿部按摩', price: '288 MOP', desc: '大腿前後深層放鬆，桑拿後最對症。' },
  { icon: '💆', name: '頭部按摩', price: '230 MOP', desc: '頭皮揉壓，緩解頭痛與精神疲勞。' },
  { icon: '🦶', name: '足底按摩（足療）', price: '230 MOP', desc: '穴位按壓，喚醒疲憊雙足。' },
  { icon: '🤚', name: '修手指甲', price: '220 MOP', desc: '修剪、塑形、護理甲緣。' },
  { icon: '🧴', name: '修腳指甲', price: '220 MOP', desc: '泡腳、修甲、甲緣護理、足部放鬆。' },
  { icon: '🤲', name: '手部按摩', price: '200 MOP', desc: '釋放手腕與前臂的緊繃感。' },

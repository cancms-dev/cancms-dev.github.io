---
import type { CallToAction } from '~/types';
import { Icon } from 'astro-icon/components';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  actions?: CallToAction[];
  images?: Array<{ src: string; alt: string }>;
}

const {
  title = '澳門桑拿．您的VIP體驗',
  subtitle = '24小時免費專車接送・送您去・接您回',
  tagline = '慶賀新店開業·7月起所有店預約即送小工',
  actions = [],
  images = [
    { src: '/images/macau-sauna-night-skyline.jpg', alt: '澳門桑拿禮賓服務 — 澳門夜景天際線・VIP 預約・豪華專車接送', objectClass: 'object-center' },
    {
      src: '/images/macau-sauna-cotai-casino-skyline-night.jpg',
      alt: '澳門桑拿 VIP 禮賓服務 — 路氹賭場夜景・豪華專車接送',
      objectClass: 'object-[20%_50%] sm:object-center',
    },
    { src: '/images/macau-sauna-tower-fireworks-night.webp', alt: '旅客專屬澳門桑拿禮賓服務 — 澳門旅遊塔煙花夜景', objectClass: 'object-[80%_50%] sm:object-center' },
  ],
} = Astro.props;

// 确保至少有一张图片
const bgImages = images.length > 0 ? images : [{ src: '/images/hero-bg.jpg', alt: '背景图片' }];
---

<section
  class="relative min-h-screen flex items-start justify-center overflow-hidden pt-[9.5rem] sm:pt-[12rem] pb-12 sm:pb-16"
>
  <!-- 背景图片容器 - 多图循环 -->
  <div class="absolute inset-0 bg-hero-container">
    {
      bgImages.map((img, index) => (
        <div
          key={index}
          class="absolute inset-0 bg-hero-item"
          data-index={index}
          style={{
            opacity: index === 0 ? 1 : 0,
            transform: 'scale(1.08)',
            transition: 'opacity 1.5s ease-in-out, transform 2.5s ease-in-out',
          }}
        >
          <img
            src={img.src}
            alt={img.alt}
            width="1920"
            height="1080"
            fetchPriority={index === 0 ? 'high' : 'low'}
            decoding="async"
            loading={index === 0 ? 'eager' : 'lazy'}
            class={`w-full h-full object-cover ${img.objectClass || 'object-center'}`}
          />
        </div>
      ))
    }
  </div>

  <!-- 渐变遮罩 -->
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/60 to-[#0a0a0a]"></div>

  <!-- 内容容器 -->

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-6">
    <h1 class="text-[28px] sm:text-4xl md:text-5xl font-bold mb-3 tracking-wider">澳門桑拿．您的VIP體驗</h1>
    <p
      data-testid="hero-free-tagline"
      class="text-sm sm:text-lg md:text-xl font-medium text-gold mb-4"
      style="opacity:1"
    >
      24小時免費專車接送・送您去・接您回
    </p>
    <p class="grid text-base min-[430px]:text-lg sm:text-lg text-white/70 mb-6 whitespace-pre-line">
      <span style="grid-area: 1 / 1; opacity: 1;">玖號水療、巨亨桑拿、曼濠水療 尚品國際水療、壹號桑拿、帝湖桑拿</span
      ><span style="grid-area: 1 / 1; opacity: 0;" aria-hidden="true"
        >豪門桑拿殿、東方皇堡水療、凱旋桑拿 尊貴水療、晉會 MCLUB、極品桑拿</span>
    </p>

    <div data-testid="hero-icon-row" class="flex items-start justify-center gap-1.5 sm:gap-4 mb-8">
      <div class="flex flex-col items-center gap-1" data-testid="hero-step-1" style="opacity:0;transform:translateX(15px)">
        <div
          class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-gold/50 border border-gold/50 flex items-center justify-center"
          style="opacity:1"
        >
        <Icon name="lucide:message-circle" class="w-5 h-5 sm:w-6 sm:h-6 text-gold" />
           
        </div><span
          class="text-white font-semibold text-sm min-[400px]:text-base min-[430px]:text-lg sm:text-lg whitespace-nowrap"
          >立即聯繫</span
        ><span class="text-xs min-[430px]:text-base sm:text-base text-center" style="opacity:1"
          ><span data-testid="desc-highlight" class="text-gold font-bold">一切交給</span><br /><span
            data-testid="desc-highlight"
            class="text-gold font-bold">我們安排</span
          ></span>
      </div><span
        data-testid="hero-arrow"
        class="text-gold text-base sm:text-xl font-black mt-2 sm:mt-3"
        style="opacity:0;transform:translateX(-10px)">→</span
      >
      
      <div class="flex flex-col items-center gap-1" data-testid="hero-step-2" style="opacity:0;transform:translateX(15px)">
        <div
          class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-gold/50 border border-gold/50 flex items-center justify-center"
          style="opacity:1"
        >
        <Icon name="lucide:car" class="w-5 h-5 sm:w-6 sm:h-6 text-gold" />
          
        </div><span
          class="text-white font-semibold text-sm min-[400px]:text-base min-[430px]:text-lg sm:text-lg whitespace-nowrap"
          ><span data-testid="step-highlight" class="text-gold">免費</span>專車接送</span
        ><span class="text-xs min-[430px]:text-base sm:text-base text-center" style="opacity:1"
          ><span data-testid="desc-highlight" class="text-gold font-bold">隨時隨地</span><br /><span class="text-white"
            >全澳接送</span
          ></span>
      </div><span
        data-testid="hero-arrow"
        class="text-gold text-base sm:text-xl font-black mt-2 sm:mt-3"
        style="opacity:0;transform:translateX(-10px)">→</span
      >
      
      <div class="flex flex-col items-center gap-1" data-testid="hero-step-3" style="opacity:0;transform:translateX(15px)">
        <div
          class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-gold/50 border border-gold/50 flex items-center justify-center"
          style="opacity:1"
        >
        <Icon name="lucide:star" class="w-5 h-5 sm:w-6 sm:h-6 text-gold" />
          
        </div><span
          class="text-white font-semibold text-sm min-[400px]:text-base min-[430px]:text-lg sm:text-lg whitespace-nowrap"
          >您只管享受</span
        ><span class="text-xs min-[430px]:text-base sm:text-base text-center" style="opacity:1"
          ><span data-testid="desc-highlight" class="text-gold font-bold">VIP 尊享</span><br /><span class="text-white"
            >優先入場</span
          ></span>
      </div>
    </div>
    
    <div class="flex flex-col items-center gap-3 w-full max-w-[280px] mx-auto">
      <a
        href="#spas"
        data-testid="hero-explore-saunas-link"
        class="relative overflow-hidden w-full px-6 py-2.5 bg-gold hover:bg-gold-dark text-black font-semibold rounded-full transition-colors duration-300 tracking-wider text-center"
        style="animation:goldGlow 2.5s ease-in-out infinite"
        ><span
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 motion-reduce:hidden"
          style="background:linear-gradient(110deg, transparent 0%, transparent 40%, rgba(255,255,255,0.55) 50%, transparent 60%, transparent 100%);background-size:200% 100%;animation:goldShimmer 3.5s linear infinite"
        ></span><span class="relative">↓ <!-- -->探索會所</span></a
      ><div class="flex w-full gap-3">
        <a
          href="#vip-treats"
          data-testid="hero-how-it-works-link"
          class="flex-1 px-3 py-2.5 border border-gold/50 text-gold hover:bg-gold/10 rounded-full transition-all duration-300 text-sm text-center"
          >服務流程</a
        ><a
          href="#contact"
          data-testid="hero-book-link"
          class="flex-1 px-3 py-2.5 border border-gold/50 text-gold hover:bg-gold/10 rounded-full transition-all duration-300 text-sm text-center"
          >立即預約</a>
      </div>
    </div>
  </div>
 


</section>

<!-- 客户端脚本：完全复刻 t1 (HomeHero.Cz-d16xB.js) 的图片切换效果 -->
<script data-astro-rerun>
  (function () {
    // ===== 参数定义（与 t1 完全一致） =====
    const INTERVAL = 4000; // 切换间隔 4000ms
    const TRANSITION_DURATION = 1400; // 过渡时长 1.4s
    const SCALE_DURATION = 5400; // 缩放持续 5.4s (INTERVAL + TRANSITION_DURATION)

    // ===== 1. 背景图轮播（完全复刻 t1 的 Framer Motion 逻辑） =====
    const bgItems = document.querySelectorAll('.bg-hero-item');
    const total = bgItems.length;
    if (total > 1) {
      let current = 0;
      let intervalId = null;
      let isTransitioning = false;

      // 为每个图片维护独立的缩放状态
      const scales = new Map();
      bgItems.forEach((item, idx) => {
        const startScale = 1.08;
        const endScale = 1.0;
        scales.set(idx, { start: startScale, end: endScale, progress: 0 });
        // 初始状态：第一张可见且放大，其他隐藏且放大
        item.style.opacity = idx === 0 ? '1' : '0';
        item.style.transform = 'scale(1.08)';
        item.style.transition = 'none';
        // 当前可见图片立即开始缓慢缩放（呼吸效果）
        if (idx === 0) {
          requestAnimationFrame(() => {
            item.style.transition = `transform ${SCALE_DURATION}ms linear`;
            item.style.transform = 'scale(1.0)';
          });
        }
      });

      function showNext() {
        if (isTransitioning) return;
        isTransitioning = true;
        const next = (current + 1) % total;
        const currentItem = bgItems[current];
        const nextItem = bgItems[next];

        // 当前图片：淡出（1.4s）+ 缓慢放大到 1.08（5.4s，与 t1 一致）
        currentItem.style.transition = `opacity ${TRANSITION_DURATION}ms ease-in-out, transform ${SCALE_DURATION}ms linear`;
        currentItem.style.opacity = '0';
        currentItem.style.transform = 'scale(1.08)';

        // 下一张图片：淡入 + 放大到 1.08（与 t1 一致：opacity 0→1, scale 1.0→1.08）
        nextItem.style.transition = `opacity ${TRANSITION_DURATION}ms ease-in-out, transform ${TRANSITION_DURATION}ms ease-in-out`;
        nextItem.style.opacity = '1';
        nextItem.style.transform = 'scale(1.08)';

        // 过渡完成后，开始下一张的呼吸缩放
        setTimeout(() => {
          // 当前图片完成过渡，重置为无过渡状态（准备下一次切换）
          currentItem.style.transition = 'none';
          // 下一张图片开始缓慢缩放（呼吸效果）：从 1.08 → 1.0
          nextItem.style.transition = `transform ${SCALE_DURATION}ms linear`;
          nextItem.style.transform = 'scale(1.0)';
        }, TRANSITION_DURATION);

        current = next;

        // 过渡完成后解锁
        setTimeout(() => {
          isTransitioning = false;
        }, TRANSITION_DURATION + 100);
      }

      function startCarousel() {
        if (intervalId) clearInterval(intervalId);
        intervalId = setInterval(showNext, INTERVAL);
      }

      function stopCarousel() {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      }

      // 页面可见性变化时控制轮播
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          stopCarousel();
        } else {
          startCarousel();
        }
      });

      // 开始轮播
      startCarousel();

      // 初始化时确保第一张可见
      bgItems[0].style.opacity = '1';
    }

    // ===== 2. 步骤入场动画（完全复刻 HomeHero.Cz-d16xB.js） =====
    // 按 DOM 顺序获取所有元素：step-1, arrow-1, step-2, arrow-2, step-3
    const container = document.querySelector('[data-testid="hero-icon-row"]');
    const allItems = container ? Array.from(container.children).filter(
      child => child.getAttribute('data-testid')?.startsWith('hero-step-') || child.getAttribute('data-testid')?.startsWith('hero-arrow')
    ) : [];

    if (allItems.length > 0) {
      // 先设置初始状态（与参考文件一致）
      allItems.forEach((item, index) => {
        const isStep = item.getAttribute('data-testid')?.startsWith('hero-step-');
        const isArrow = item.getAttribute('data-testid')?.startsWith('hero-arrow');
        
        item.style.opacity = '0';
        if (isStep) {
          item.style.transform = 'translateY(15px)';
        } else if (isArrow) {
          item.style.transform = 'translateX(-8px)';
        }
        item.style.transition = 'opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1)';
        // 延迟计算：参考 a === 0 ? 0.1 : a * 0.35 + 0.15
        const delay = index === 0 ? 0.1 : index * 0.35 + 0.15;
        item.style.transitionDelay = delay + 's';
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const isStep = entry.target.getAttribute('data-testid')?.startsWith('hero-step-');
              const isArrow = entry.target.getAttribute('data-testid')?.startsWith('hero-arrow');
              
              entry.target.style.opacity = '1';
              if (isStep) {
                entry.target.style.transform = 'translateY(0)';
              } else if (isArrow) {
                entry.target.style.transform = 'translateX(0)';
              }
            }
          });
        },
        { threshold: 0.2 }
      );

      allItems.forEach((item) => observer.observe(item));
    }

    // ===== 3. 文字切换（两个 span 交替显示） =====
    const textSpans = document.querySelectorAll('.grid.whitespace-pre-line > span');
    if (textSpans.length > 1) {
      let currentIndex = 0;
      let textIntervalId = null;

      function switchText() {
        const nextIndex = (currentIndex + 1) % textSpans.length;
        textSpans[currentIndex].style.opacity = '0';
        textSpans[nextIndex].style.opacity = '1';
        currentIndex = nextIndex;
      }

      function startTextSwitch() {
        if (textIntervalId) clearInterval(textIntervalId);
        textIntervalId = setInterval(switchText, INTERVAL);
      }

      function stopTextSwitch() {
        if (textIntervalId) {
          clearInterval(textIntervalId);
          textIntervalId = null;
        }
      }

      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          stopTextSwitch();
        } else {
          startTextSwitch();
        }
      });

      startTextSwitch();
    }
  })();
</script>

<style>

.grid.whitespace-pre-line > span {
    margin: 0 auto;
    width: 54%
}  
</style>
<style is:global>
  /* 金色主题颜色 */
  .text-gold {
    color: #d4af37;
  }
  .border-gold {
    border-color: #d4af37;
  }
  .bg-gold {
    background-color: #d4af37;
  }
  .bg-gold\/50 {
    background-color: rgba(212, 175, 55, 0.5);
  }
  .border-gold\/50 {
    border-color: rgba(212, 175, 55, 0.5);
  }
  .hover\:bg-gold-dark:hover {
    background-color: #b8962e;
  }
  .hover\:shadow-gold\/30:hover {
    box-shadow: 0 0 30px rgba(212, 175, 55, 0.3);
  }

  /* 过渡动画 */
  [data-step],
  [data-step-arrow] {
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* 文字切换渐变 */
  .grid.whitespace-pre-line > span {
    transition: opacity 0.7s ease-in-out;
  }
</style>

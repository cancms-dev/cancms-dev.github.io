  <!-- 在 <script> 标签上添加 data-astro-rerun 属性，Astro 会在每次页面切换后重新执行该脚本 -->
  <script type="module" data-astro-rerun>
    setTimeout(() => {
      document.querySelectorAll('.fade-up:not(.in-view)').forEach((el) => el.classList.add('in-view'));
    }, 200);
  </script>

  <!-- Smooth Scroll Script -->

  <script type="module"  data-astro-rerun>
    document.addEventListener('click', (e) => {
      const link = e.target.closest('[data-smooth-scroll]');
      if (!link) return;
      const href = link.getAttribute('href');
      if (href && href.includes('#')) {
        e.preventDefault();
        const target = document.querySelector('#' + href.split('#')[1]);
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  </script>
